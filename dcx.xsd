            <xs:documentation>
                Ensure that the content of the dcx:connectedTo element in a dcx:setting points to the @id of a dcx:equipment.
            </xs:documentation>
        </xs:annotation>
        <xs:selector xpath="dcx:settingList/dcx:setting"/>
        <xs:field xpath="dcx:connectedTo"/>
    </xs:keyref><!--tested-->
    <xs:keyref name="statementRefSetting2equipment" refer="dcx:PKstatement">
        <xs:annotation>
            <xs:documentation>
                Ensure that the content of the dcx:statementRef element in a dcx:setting points to the @id of a dcx:statement.
            </xs:documentation>
        </xs:annotation>
        <xs:selector xpath="dcx:settingList/dcx:setting"/>
