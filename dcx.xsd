    <!-- table column -->
    <!--xs:keyref name="tableColumnQuantityDefRef2quantityDefRef" refer="dcx:PKquantityDefRef">
        <xs:selector xpath="dcx:measurementResultList/*/dcx:column"/>
        <xs:field xpath="@quantityUnitDefRef"/> 
    </xs:keyref--> <!--fails due to NULL default of quantityUnitDefRef-->

    <!--   table column rows with references   -->
