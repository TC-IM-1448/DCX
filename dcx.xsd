            </xs:documentation>
        </xs:annotation>
        <xs:selector xpath="dcx:measurementResultList/*/dcx:column/dcx:exceptionRef/dcx:row"/>
        <xs:field xpath="."/>
    </xs:keyref>
    <xs:keyref name="accExceptionRefColumn2statement" refer="dcx:PKstatement">
