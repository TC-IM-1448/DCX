            </xs:documentation>
        </xs:annotation>
        <xs:selector xpath="dcx:measurementResultList/*/dcx:column/dcx:accreditationExceptionRef/dcx:row"/>
        <xs:field xpath="."/>
    </xs:keyref>
    <xs:keyref name="decisionRuleRefColumn2statement" refer="dcx:PKstatement">
        <xs:annotation>
            <xs:documentation>
                Ensure that the row content of a dcx:column with dataCategory dcx:decisionRuleRef points to the @id of a dcx:statement.
            </xs:documentation>
