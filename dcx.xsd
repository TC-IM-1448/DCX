    <!-- =============== ELEMENT TYPES for the xs:choice options within columnType  ==================== -->

    <xs:complexType name="valueType">
        <xs:annotation>
            <xs:documentation>
                Used with scope= "reference" to report the best estimate of a value of a quantity using the reference standard equipment.
                Used with scope= "indication" to report the instrument indication value of the device for measurement. The indication may be a single reading or the best estimate (average) based on a number of readings.
                Used with scope= "bias" to report the value of instrumental bias. I.e. (reference standard value - instrument indication value).
                For a given quantity and scope, columns of valueType may be stated multiple times with different unit attributes.
                Used exclusively with dataCategoryRef="value".
            </xs:documentation>
        </xs:annotation>
        <xs:complexContent>
            <xs:extension base='dcx:realDataType'>
                <xs:attribute name="dataCategory" type="xs:string" fixed="value"/>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="targetValueType">
        <xs:annotation>
            <xs:documentation>
                targetValueType is used for predefined calibration points, either for specification in request (DCR) hence typically agreed with the client before calibration or for documentation purposes.
            </xs:documentation>
        </xs:annotation>
        <xs:complexContent>
            <xs:extension base='dcx:realDataType'>
                <xs:attribute name="dataCategory" type="xs:string" fixed="targetValue"/>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>


    <xs:complexType name="expandedUncertaintyType">
        <xs:annotation>
            <xs:documentation>
                expandedUncertaintyType is used to report the expanded uncertainty of a measurement result, which is typically calculated by multiplying the combined standard uncertainty by a coverage factor uncertaintyCoverageFactor_k.
            </xs:documentation>
        </xs:annotation>
        <xs:complexContent>
            <xs:extension base='dcx:realDataType'>
                <xs:attribute name="dataCategory" type="xs:string" fixed="expandedUncertainty"/>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>


    <xs:complexType name="correlationType">
        <xs:annotation>
            <xs:documentation>
                correlationType is used to report the correlation between different measurement results or quantities.
            </xs:documentation>
        </xs:annotation>
        <xs:complexContent>
            <xs:extension base='dcx:realDataType'>
                <xs:attribute name="dataCategory" type="xs:string" fixed="correlation"/>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="correctionType">
        <xs:annotation>
            <xs:documentation>
                correctionType is used together with the bias scope to express a correction for bias for material measures. The correction value is typically calculated as the difference between the measurement result and a reference value, e.g. the nominal value of an artefact or the display value of an active instrument.
            </xs:documentation>
        </xs:annotation>
        <xs:complexContent>
            <xs:extension base='dcx:realDataType'>
                <xs:attribute name="dataCategory" type="xs:string" fixed="correction"/>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>


    <xs:complexType name="statStdType">
        <xs:annotation>
            <xs:documentation>
                Used to report the standard deviation of a series of measurements, which is typically calculated as the square root of the variance of the measurements.
            </xs:documentation>
        </xs:annotation>
        <xs:complexContent>
            <xs:extension base='dcx:realDataType'>
                <xs:attribute name="dataCategory" type="xs:string" fixed="statStd"/>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="statMinType">
        <xs:annotation>
            <xs:documentation>
                Used to report the minimum value of a series of measurements.
            </xs:documentation>
        </xs:annotation>
        <xs:complexContent>
            <xs:extension base='dcx:realDataType'>
                <xs:attribute name="dataCategory" type="xs:string" fixed="statMin"/>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="statMaxType">
        <xs:annotation>
            <xs:documentation>
                Used to report the maximum value of a series of measurements.
            </xs:documentation>
        </xs:annotation>
        <xs:complexContent>
            <xs:extension base='dcx:realDataType'>
                <xs:attribute name="dataCategory" type="xs:string" fixed="statMax"/>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>


    <xs:complexType name="conformityType">
        <xs:annotation>
            <xs:documentation>
                Used for pass/fail assessment of the calibration. Typically used in conjunction with a meta data column referring to a statement with description of the assessment basis. The conformity status is typically based on comparison of measurement results with specified limits, e.g. tolerance limits or acceptance limits, but may also be based on other criteria such as agreement with reference values or compliance with decision rules.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name='row' minOccurs='0' maxOccurs='unbounded'>
                <xs:complexType>
                    <xs:simpleContent>
                        <xs:extension base='dcx:conformityStatusType'>
                            <xs:attribute name='idx' type='xs:int'/>
                        </xs:extension>
                    </xs:simpleContent>
                </xs:complexType>
            </xs:element>
        </xs:sequence>
        <xs:attribute name="dataCategory" type="xs:string" fixed="conformity"/>
    </xs:complexType>

 
    <xs:complexType name="rowTagType">
        <xs:annotation>
            <xs:documentation>
                Used to report tags for rows in the data table, e.g. to identify calibration points or measurement series. These can e.g. be used by clients to link the data rows to own database identifiers, external references or metadata. 
            </xs:documentation>
        </xs:annotation>
        <xs:complexContent>
            <xs:extension base='dcx:stringDataType'>
                <xs:attribute name="dataCategory" type="xs:string" fixed="rowTag"/>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>


    <xs:complexType name="usedReferenceRefType">
        <xs:annotation>
            <xs:documentation>
                Can be used to specify which reference standard was used for measuremensts of each row. The reference standard can be specified in the dcx:equipmentList (using category: referenceStandard) and linked to the row by its id.
            </xs:documentation>
        </xs:annotation>
        <xs:complexContent>
            <xs:extension base='dcx:refDataType'>
                <xs:attribute name="dataCategory" type="xs:string" fixed="usedReferenceRef"/>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="methodRefType">
        <xs:annotation>
            <xs:documentation>
                Can be used to specify which method was used for each measurement. The method can be specified in the dcx:statement (using category: method) and linked to the row by its id.
            </xs:documentation>
        </xs:annotation>
        <xs:complexContent>
            <xs:extension base='dcx:refDataType'>
                <xs:attribute name="dataCategory" type="xs:string" fixed="methodRef"/>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="exceptionRefType">
        <xs:annotation>
            <xs:documentation>
                Can be used to specify which exceptions apply to each measurement row. The exceptions can be specified in the dcx:statement (using category: exception) and linked to the row by its id.
            </xs:documentation>
        </xs:annotation>
        <xs:complexContent>
            <xs:extension base='dcx:refDataType'>
                <xs:attribute name="dataCategory" type="xs:string" fixed="exceptionRefType"/>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>


    <xs:complexType name="traceabilityRefType">
        <xs:annotation>
            <xs:documentation>
                Can be used to specify which traceability information applies to each measurement row. The traceability information can be specified in the dcx:statement (using category: traceability) and linked to the row by its id.
            </xs:documentation>
        </xs:annotation>
        <xs:complexContent>
            <xs:extension base='dcx:refDataType'>
                <xs:attribute name="dataCategory" type="xs:string" fixed="traceabilityRef"/>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="attentionRefType">
        <xs:annotation>
            <xs:documentation>
                Can be used to specify which attention information applies to each measurement row. The attention information can be specified in the dcx:statement (using category: attention) and linked to the row by its id.
            </xs:documentation>
        </xs:annotation>
        <xs:complexContent>
            <xs:extension base='dcx:refDataType'>
                <xs:attribute name="dataCategory" type="xs:string" fixed="attentionRef"/>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="commentRefType">
        <xs:annotation>
            <xs:documentation>
                Can be used to specify which comments apply to each measurement row. The comments can be specified in the dcx:statement (using category: comment) and linked to the row by its id.
            </xs:documentation>
        </xs:annotation>
        <xs:complexContent>
            <xs:extension base='dcx:refDataType'>
                <xs:attribute name="dataCategory" type="xs:string" fixed="commentRef"/>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="decisionRuleRefType">
        <xs:annotation>
            <xs:documentation>
                Can be used to specify which decision rules apply to each measurement row. The decision rules can be specified in the dcx:statement (using category: decisionRule) and linked to the row by its id.
            </xs:documentation>
        </xs:annotation>
        <xs:complexContent>
            <xs:extension base='dcx:refDataType'>
                <xs:attribute name="dataCategory" type="xs:string" fixed="decisionRuleRef"/>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="accreditationExceptionRefType">
        <xs:annotation>
            <xs:documentation>
                Can be used to specify if an accreditation exceptions apply (is true) at in a table row. The accreditation exceptions can be specified in the dcx:statement (using category: accreditationException) and linked to the row by its id.
            </xs:documentation>
        </xs:annotation>
        <xs:complexContent>
            <xs:extension base='dcx:refDataType'>
                <xs:attribute name="dataCategory" type="xs:string" fixed="accreditationExceptionRef"/>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="normRefType">
        <xs:annotation>
            <xs:documentation>
                Can be used to specify which specific standards are used for each measurement row. The reference standards can be specified in the dcx:statement (using category: referenceStandard) and linked to the row by its id.
            </xs:documentation>
        </xs:annotation>
        <xs:complexContent>
            <xs:extension base='dcx:refDataType'>
                <xs:attribute name="dataCategory" type="xs:string" fixed="normRef"/>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="measurementSeriesRefType">
        <xs:annotation>
            <xs:documentation>
                Can be used to reference which measurement series is used for each measurement row. The measurement series should be provided in dcx:measurementSeries data-tables.
            </xs:documentation>
        </xs:annotation>
        <xs:complexContent>
            <xs:extension base='dcx:refDataType'>
                <xs:attribute name="dataCategory" type="xs:string" fixed="measurementSeriesRef"/>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="uncertaintyCoverageFactor_kType">
        <xs:annotation>
            <xs:documentation>
                Can be used to specify the coverage factor k for the expanded uncertainty of a measurement result. The coverage factor k is typically used to calculate the expanded uncertainty by multiplying it with the combined standard uncertainty.
            </xs:documentation>
        </xs:annotation>
        <xs:complexContent>
            <xs:extension base='dcx:realDataType'>
                <xs:attribute name="dataCategory" type="xs:string" fixed="uncertaintyCoverageFactor_k"/>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="uncertaintyCoverageProbabilityType">
        <xs:annotation>
            <xs:documentation>
                Can be used to specify the coverage probability for the expanded uncertainty of a measurement result. 
            </xs:documentation>
        </xs:annotation>
        <xs:complexContent>
            <xs:extension base='dcx:realDataType'>
                <xs:attribute name="dataCategory" type="xs:string" fixed="uncertaintyCoverageProbability"/>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType  name="toleranceLimitLowerType">
        <xs:annotation>
            <xs:documentation>
                Can be used to specify the lower tolerance limit for a measurement result.
            </xs:documentation>
        </xs:annotation>
        <xs:complexContent>
            <xs:extension base='dcx:realDataType'>
                <xs:attribute name="dataCategory" type="xs:string" fixed="toleranceLimitLower"/>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="toleranceLimitUpperType">
        <xs:annotation>
            <xs:documentation>
                Can be used to specify the upper tolerance limit for a measurement result.
            </xs:documentation>
        </xs:annotation>
        <xs:complexContent>
            <xs:extension base='dcx:realDataType'>
                <xs:attribute name="dataCategory" type="xs:string" fixed="toleranceLimitUpper"/>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="acceptanceLimitLowerType">
        <xs:annotation>
            <xs:documentation>
                Can be used to specify the lower acceptance limit for a measurement result.
            </xs:documentation>
        </xs:annotation>
        <xs:complexContent>
            <xs:extension base='dcx:realDataType'>
                <xs:attribute name="dataCategory" type="xs:string" fixed="acceptanceLimitLower"/>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>


    <xs:complexType name="acceptanceLimitUpperType">
        <xs:annotation>
            <xs:documentation>
                Can be used to specify the upper acceptance limit for a measurement result.
            </xs:documentation>
        </xs:annotation>
        <xs:complexContent>
            <xs:extension base='dcx:realDataType'>
                <xs:attribute name="dataCategory" type="xs:string" fixed="acceptanceLimitUpper"/>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>


    <xs:complexType name="approachToTargetType">
        <xs:annotation>
            <xs:documentation>
                Can be used to specify the approach to target for a measurement result. 
                The approach to target can either be: 
                    a: from above
                    b: from below
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name='row' minOccurs='0' maxOccurs='unbounded'>
                <xs:complexType>
                    <xs:simpleContent>
                        <xs:extension base='dcx:approachToTargetRestrictType'>
                            <xs:attribute name='idx' type='xs:int'/>
                        </xs:extension>
                    </xs:simpleContent>
                </xs:complexType>
            </xs:element>
        </xs:sequence>
        <xs:attribute name="dataCategory" type="xs:string" fixed="approachToTarget"/>
    </xs:complexType>
    
    <xs:complexType name="instrumentResolutionType">
        <xs:annotation>
            <xs:documentation>
                Can be used to specify the resolution of the instrument for a measurement result.
            </xs:documentation>
        </xs:annotation>
        <xs:complexContent>
            <xs:extension base='dcx:realDataType'>
                <xs:attribute name="dataCategory" type="xs:string" fixed="instrumentResolution"/>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    
    <xs:complexType name="hysteresisType">
        <xs:annotation>
            <xs:documentation>
                Use with scope="indication" to report the difference between the indication of a quantity as measured from below or from above.
            </xs:documentation>
        </xs:annotation>
        <xs:complexContent>
            <xs:extension base='dcx:realDataType'>
                <xs:attribute name="dataCategory" type="xs:string" fixed="hysteresis"/>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="calibrationFactorType">
        <xs:annotation>
            <xs:documentation>
                Used with scope="bias" to report the ratio between the reference standard value and the instrument indication value (i.e. (reference standard value) / (instrument indication value) )
            </xs:documentation>
        </xs:annotation>
        <xs:complexContent>
            <xs:extension base='dcx:realDataType'>
                <xs:attribute name="dataCategory" type="xs:string" fixed="calibrationFactor"/>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>


    <xs:complexType name="relativeToIndicationValueType">
        <xs:annotation>
            <xs:documentation>
                Used with scope="bias" to report the relative value of the instrumental bias (i.e. (reference standard value - instrument indication value)/(instrument indication value) )
                Used with scope="bias" ( or "indication") and dataCategoryRef="expandedUncertainty" to report relative uncertainties.
                Used with scope="indication" (or "bias") and an appropriate dataCategoryRef to report on relative hysteresis, relative resolution, relative repeatability, relativeToleranceLimit, relative correction ...etc.
            </xs:documentation>
        </xs:annotation>
        <xs:complexContent>
            <xs:extension base='dcx:realDataType'>
                <xs:attribute name="dataCategory" type="xs:string" fixed="relativeToIndicationValue"/>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>



    <xs:complexType name="otherType">
        <xs:annotation>
            <xs:documentation>
                Can be used to specify other types of data that do not fall into the predefined categories.
            </xs:documentation>
        </xs:annotation>
        <xs:complexContent>
            <xs:extension base='dcx:stringDataType'>
                <xs:attribute name="dataCategory" type="xs:string" fixed="other"/>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <!-- =========== END of dataColumn element types   ==================== -->
    
    <!--=============================================================
                Embedded Files Types
        =============================================================-->

    <xs:complexType name="embeddedFileListType">
        <xs:annotation>
            <xs:documentation>
                List of embedded files
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
			<xs:element name="heading" type="dcx:stringWithLangType" minOccurs="0" maxOccurs="unbounded"/>
            <xs:element name="embeddedFile" type="dcx:embeddedFileType" minOccurs="0" maxOccurs="unbounded"/>
            <xs:element name="columnHeadings" type="dcx:embeddedFileColumnHeadingsType" minOccurs="0">
                <xs:unique name="uniqueEmbeddedFileColumnHeadings">
                    <xs:selector xpath="dcx:column"/>
                    <xs:field xpath="@name"/>
                </xs:unique>
            </xs:element>
        </xs:sequence>
        <xs:attribute name="id" type="xs:ID" use="optional"/>
    </xs:complexType>

    <xs:complexType name="embeddedFileType">
        <xs:annotation>
            <xs:documentation>
                The embeddedFileType defines a type which allows to add binary encoded files to the measurement result
                section. This can be used to e.g. attach: measurement specification drawings, logo images, plots of measurement results and calibration curves. 
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="heading" type="dcx:stringWithLangType" minOccurs="0" maxOccurs="unbounded"/>
            <xs:element name="body" type="dcx:stringWithLangType" minOccurs="0" maxOccurs="unbounded"/>
            <xs:element name="fileExtension" type="dcx:notEmptyStringType"/>
            <xs:element name="fileContent" type="xs:base64Binary"/>
        </xs:sequence>
        <xs:attribute name="id" type="xs:ID" use="optional"/>
    </xs:complexType>


        <xs:complexType name="embeddedFileColumnHeadingsType">
            <xs:annotation>
                <xs:documentation>
                    Used to provide common headings for the embeddedFile sub elements. 
                </xs:documentation>
            </xs:annotation>
            <xs:sequence>
                <xs:element name="column" maxOccurs="unbounded">
                    <xs:complexType>
                        <xs:sequence>
                            <xs:element name="heading" type="dcx:stringWithLangType" minOccurs="1" maxOccurs="unbounded"/>
                        </xs:sequence>
                        <xs:attribute name="name" type="dcx:embeddedFileColumnHeadingNamesType" use="required"/>
                    </xs:complexType>
                    <xs:unique name="uniqueLanguageEmbeddedFile">
                        <xs:selector xpath="dcx:heading"/>
                        <xs:field xpath="@lang"/>
                    </xs:unique>
                </xs:element>
            </xs:sequence>
        </xs:complexType>
    
        <xs:simpleType name="embeddedFileColumnHeadingNamesType">
            <xs:annotation>
                <xs:documentation>
                </xs:documentation>
            </xs:annotation>
                <xs:restriction base="xs:string">
                    <xs:enumeration value="@id" /> 
                    <xs:enumeration value="@idRef" /> 
                    <xs:enumeration value="@quantityCodeSystem" /> 
                    <xs:enumeration value="@statementRefs" /> 
                    <xs:enumeration value="heading" /> 
                    <xs:enumeration value="quantityCode" /> 
                    <xs:enumeration value="unitUsed" /> 
                    <xs:enumeration value="functionToSIunit" /> 
                    <xs:enumeration value="unitSI" /> 
                    <xs:enumeration value="externalRefs" />
                </xs:restriction>
        </xs:simpleType>
        

