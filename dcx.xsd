        <xs:selector xpath="dcx:measurementConfigList/dcx:measurementConfig/dcx:statementRefs"/>
        <xs:field xpath="."/>
    </xs:keyref-->

    <!-- table  -->
    <xs:keyref name="table2measConfig" refer="dcx:PKmeasurementConfig">
